generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==================== AUTH & USERS ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  accounts       Account[]
  sessions       Session[]
  documents      Document[]
  auditLogs      AuditLog[]
  comments       Comment[]

  @@index([organizationId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== ORGANIZATION (MULTI-TENANT) ====================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Billing
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  plan                 Plan    @default(FREE)
  planExpiresAt        DateTime?

  // Relations
  members   User[]
  documents Document[]
  folders   Folder[]
  auditLogs AuditLog[]
  apiKeys   ApiKey[]

  @@index([slug])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ==================== DOCUMENTS ====================

model Document {
  id          String         @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  status      DocumentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // AI-generated metadata
  summary     String?        @db.Text
  category    String?
  tags        String[]
  extractedText String?      @db.Text
  language    String?

  // Embedding for semantic search
  embedding   Unsupported("vector(1536)")?

  // Relations
  uploadedById   String
  uploadedBy     User         @relation(fields: [uploadedById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?      @relation(fields: [folderId], references: [id])
  permissions    Permission[]
  comments       Comment[]
  versions       DocumentVersion[]

  @@index([organizationId])
  @@index([folderId])
  @@index([uploadedById])
  @@index([status])
  @@index([category])
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model DocumentVersion {
  id         String   @id @default(cuid())
  version    Int
  fileName   String
  fileUrl    String
  fileSize   Int
  createdAt  DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ==================== FOLDERS ====================

model Folder {
  id        String   @id @default(cuid())
  name      String
  color     String?  @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Self-referencing for nested folders
  parentId String?
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[] @relation("FolderTree")

  // Relations
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      Document[]
  permissions    Permission[]

  @@index([organizationId])
  @@index([parentId])
}

// ==================== PERMISSIONS ====================

model Permission {
  id        String         @id @default(cuid())
  level     PermissionLevel
  createdAt DateTime       @default(now())

  // Can be applied to document or folder
  userId     String?
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  folderId   String?
  folder     Folder?   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
  @@index([folderId])
}

enum PermissionLevel {
  VIEW
  EDIT
  ADMIN
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ==================== COMMENTS ====================

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

// ==================== API KEYS ====================

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([organizationId])
}
